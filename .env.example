# Firebase Configuration for FCM Push Notifications
# 
# To enable Firebase Cloud Messaging:
# 1. Create a Firebase project at https://console.firebase.google.com
# 2. Go to Project Settings → Service Accounts → Generate New Private Key
# 3. Save the JSON file as: backend/firebase-service-account.json
# 4. The Docker container will automatically load it from this path
#
# Note: firebase-service-account.json is gitignored (never committed)
# This file is ONLY needed for local testing or production deployment
FIREBASE_SERVICE_ACCOUNT_PATH=./backend/firebase-service-account.json
