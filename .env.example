# MRRG Production Configuration Template
# Copy this file to .env and fill with real values for deployment
# Never commit .env with real secrets

# ========== DATABASE ==========
POSTGRES_DB=mrrg
POSTGRES_USER=mrrg
POSTGRES_PASSWORD=your_secure_password_here

# ========== BACKEND DATABASE CONNECTION ==========
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mrrg
SPRING_DATASOURCE_USERNAME=mrrg
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ========== BACKEND - AUTHENTICATION ==========
# JWT secret key (generate a strong random value in production)
JWT_SECRET=your_jwt_secret_key_here

# ========== BACKEND - FIREBASE ==========
# Path to Firebase service account JSON file (outside Git)
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json

# ========== BACKEND - EMAIL (SMTP) ==========
SPRING_MAIL_HOST=smtp.provider.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@provider.com
SPRING_MAIL_PASSWORD=your_email_password_here
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_FROM=noreply@yourdomain.com

# ========== BACKEND - FRONTEND COMMUNICATION ==========
# CORS allowed origin for frontend
FRONTEND_ORIGIN=https://yourdomain.com

# ========== BACKEND - ACCOUNT ACTIVATION ==========
# Activation link base URL (deep link or HTTPS URL)
ACTIVATION_LINK_BASE_URL=https://yourdomain.com/activate
# Token expiration in hours
ACTIVATION_TOKEN_EXPIRATION_HOURS=24

# ========== BACKEND - HIBERNATE ==========
# For production: validate (do not auto-create/update)
# Requires proper database migration strategy
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ========== BACKEND - PROFILE ==========
# Local development: dev, Production: prod
SPRING_PROFILES_ACTIVE=prod

# ========== BACKEND - INITIAL ADMIN BOOTSTRAP (optional, first install only) ==========
# Creates the first ADMIN when no administrator exists yet. Skipped if an ADMIN already exists.
# INITIAL_ADMIN_EMAIL=admin@yourdomain.com
# INITIAL_ADMIN_PASSWORD=your_secure_admin_password_here
# INITIAL_ADMIN_NAME=Administrator
# APP_BOOTSTRAP_INITIAL_ADMIN_ENABLED=true

# ========== FRONTEND - API ENDPOINT ==========
# React Vite environment variable for backend API URL
VITE_API_BASE_URL=https://api.yourdomain.com
